# --- Supabase (필수) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Google AI (서버 전용 권장 — 코드/깃에 절대 커밋하지 마세요) ---
GOOGLE_GENERATIVE_AI_API_KEY=
# 또는
# GEMINI_API_KEY=

# 하위 호환: 클라이언트 번들에 노출되므로 프로덕션에서는 비권장
# NEXT_PUBLIC_GOOGLE_GENERATIVE_AI_API_KEY=

GEMINI_VISION_MODEL=
GEMINI_API_VERSION=
GEMINI_API_BASE_URL=

# --- API 사용량 / 레이트 리밋 / 예산 ---
LUMINA_ADMIN_SECRET=
LUMINA_RATE_LIMIT_IP_SALT=
LUMINA_RATE_LIMIT_PER_MINUTE=24
LUMINA_RATE_LIMIT_PER_HOUR=180
LUMINA_API_BLOCK_DURATION_MS=900000
LUMINA_MONTHLY_BUDGET_USD=

# 기능별 호출당 추정 비용(USD) — Google Cloud 청구에 맞게 조정
LUMINA_COST_USD_ANALYZE_PRODUCT=0.002
LUMINA_COST_USD_ANALYZE_PRODUCT_STREAM=0.002
LUMINA_COST_USD_GENERATE_BACKGROUND=0.04
LUMINA_COST_USD_REFINE_COPY=0.0008
LUMINA_COST_USD_EXPORT_LAUNCH_BUNDLE=0
LUMINA_COST_USD_GENESIS_RENDER_QUEUE=0

# 기능별 분/시간 한도 (선택, 미설정 시 위 전역값 사용)
# LUMINA_RATE_LIMIT_ANALYZE_PRODUCT_PER_MINUTE=
# LUMINA_RATE_LIMIT_ANALYZE_PRODUCT_PER_HOUR=

LUMINA_CREDITS_USER_ID=

# 루미나 헌장·프롬프트 (선택) — 0 이면 해당 블록 비활성
# LUMINA_NARRATIVE_SPEAR_CHARTER=
# 플래그십 브랜드 시드(쉼표 또는 |) — narrative-spear 프롬프트에 주입
# LUMINA_FLAGSHIP_BRAND_NAMES=
# 비주얼–언어 동기화 프롬프트 블록 끄기: LUMINA_DUAL_SYNCHRO_CHARTER=0
# 맨 용기·카드 패키징 블록 끄기: LUMINA_NAKED_VESSEL_CARD_CHARTER=0
# 구소 매크로 미학(Origin 히어로·Jewel-Tex·맨 유리 지휘) 끄기: LUMINA_GUSO_MACRO_AESTHETICS=0 (구소 헌장이 꺼지면 이 블록도 비활성)
# LUMINA_GUSO_MACRO_AESTHETICS=
# 求小 1순위 Micro-Sense(입자 클로즈업·Quiet copy): 끄기=0 강제=1 · 미설정 시 매크로와 함께 켜짐
# LUMINA_GUSO_MICRO_SENSE_PRIORITY=
# 입자가 떠 있는 오일·세럼 점도 힌트: light | dense | neutral(또는 비움) — 한글 별칭: 물/순수→light, 꿀/묵직→dense (물 같은 순수 제형: light)
# LUMINA_ORIGIN_FLUID_VISCOSITY=light
# 정갈한 카드 비주얼: typography | botanical_line | neutral(또는 비움) — 타이포 중심(언어의 알몸): typography
# LUMINA_ORIGIN_CARD_LAYOUT_BIAS=typography
# 카드 종이 톤: pure_white | raw_beige | neutral(또는 비움) — 순백(결백·Sacred Silence): pure_white
# LUMINA_ORIGIN_CARD_PAPER_TONE=pure_white
# 카드 본문 서체 성격: sans | serif | neutral — 명조(Sacred Serif): serif 또는 명조
# LUMINA_ORIGIN_CARD_FONT_BIAS=serif
# 언박싱 첫 순간: visual_neutral(무채색 고요·침묵의 언박싱) | olfactory_raw(날것 향, 팩트 일치 시만) | neutral
# LUMINA_ORIGIN_UNBOXING_BIAS=visual_neutral
# 관리자 대시보드 상단 오늘의 한 줄(비우면 마스터 모토: 없다의 실천으로 모두를 품다)
# LUMINA_ADMIN_DAILY_SLOGAN_KO=
# 마스터 모토 프롬프트·Legal Trace 블록 끄기: LUMINA_MASTER_MOTTO_CHARTER=0
# LUMINA_MASTER_MOTTO_CHARTER=
# 제1 원칙(본질·근원·사실) 프롬프트·Legal Trace 블록 끄기: LUMINA_FIRST_PRINCIPLE_CHARTER=0
# LUMINA_FIRST_PRINCIPLE_CHARTER=
# 고객 감동(순백 밀서·감각 레이어) 프롬프트·Legal Trace 블록 끄기: LUMINA_CUSTOMER_IMPRESSION_CHARTER=0
# LUMINA_CUSTOMER_IMPRESSION_CHARTER=
# Raw Scent 내러티브(후각 정직·텍스처-향 동기 프롬프트): 미설정 시 매크로 미학과 함께 켜짐. 끄기 LUMINA_RAW_SCENT_NARRATIVE=0 · 단독 강제 켬=1
# LUMINA_RAW_SCENT_NARRATIVE=
# Legal Trace 푸터에 「합성 향료 0%」 배지 줄을 넣으려면 법무·전성분 검증 후에만 1
# LUMINA_RAW_SCENT_ZERO_SYNTHETIC_SUBSTANTIATED=
# 2030 영-니치 타깃 프롬프트: 미설정 시 Raw Scent와 함께 켜짐. 끄기=0 단독 켬=1
# LUMINA_YOUNG_NICHE_TARGETING=
# 삼求(求小·求苦·求己) 프롬프트 블록 끄기: LUMINA_TRINITY_CHARTER=0
# 카드 재질 톤(선택): earthy | refined | neutral (비우면 neutral — 브랜드 선택 존중)
# LUMINA_CARD_STOCK_PRESET=
